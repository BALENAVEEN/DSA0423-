import numpy as np

# rows = students, columns = subjects
student_scores = np.array([
    [80, 75, 90, 85],
    [70, 88, 92, 78],
    [85, 80, 86, 90],
    [90, 85, 88, 82]
])

subjects = ["Math", "Science", "English", "History"]

# average per subject
avg_scores = student_scores.mean(axis=0)

# highest average subject
highest_index = np.argmax(avg_scores)

print("Average scores:", avg_scores)
print("Highest average subject:", subjects[highest_index])
