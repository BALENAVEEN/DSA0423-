import numpy as np

# columns: bedrooms, sqft, price
house_data = np.array([
    [3, 1200, 200000],
    [5, 2000, 350000],
    [4, 1500, 250000],
    [6, 2200, 400000]
])

filtered = house_data[house_data[:, 0] > 4]
avg_price = filtered[:, 2].mean()

print("Average price (bedrooms >4):", avg_price)
